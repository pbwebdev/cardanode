# Copy to .dev.vars for local `wrangler dev` (gitignored).
# In production set the same names via `wrangler secret put <NAME>`.

# Required for /api/contact
TURNSTILE_SECRET=
CONTACT_TO=peter@meshwithus.com.au

# Optional — only set if you need the Blockfrost fallback proxy.
# Koios is the primary data source and needs no key.
BLOCKFROST_KEY=
