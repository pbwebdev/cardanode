# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.swp
.vscode/
.idea/

# Accidental Windows copies
*- Copy.html
*- Copy*.html
* - Copy.*

# Node
node_modules/
.wrangler/

# Build output — public/ is fully regenerated from src/static/, src/content/,
# build.js, build-mesh.js, and build-posts.js. Source of truth lives in src/.
src/version-data.js
public/*
!public/.gitkeep

# Migration source (keep WXR + raw exports out of the repo)
_temp/
*.wxr
*_WordPress_*.xml

# Downloaded media (50-100 MB of WordPress uploads). Pulled via
# `npm run media` from cardanode.com.au's CDN; build.js copies into
# public/uploads/ each build. Not for git.
src/static/uploads/

# Secrets — never commit
.dev.vars
.env
.env.*
!.env.example
